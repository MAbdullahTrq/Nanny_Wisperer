# App
# For local dev use http://localhost:3000. On VPS use the URL users actually use
# (e.g. http://YOUR_VPS_IP:3000 or https://yourdomain.com) — login redirects use this.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Auth (NextAuth)
# Must match the URL users use to reach the app (same as NEXT_PUBLIC_APP_URL on VPS).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-secret

# Tokens (JWT / shortlist, CV, interview)
JWT_SECRET=generate-a-secure-secret
# or
TOKEN_SECRET=generate-a-secure-secret

# Google (OAuth, Calendar, Meet)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=

# VIP: Kayley's calendar for overlap (T8.5)
KAYLEY_CALENDAR_ID=
KAYLEY_REFRESH_TOKEN=

# GHL (GoHighLevel)
GHL_API_KEY=
GHL_ACCOUNT_ID=
GHL_WEBHOOK_SECRET=
# Webhook URL: POST {NEXT_PUBLIC_APP_URL}/api/webhooks/ghl — set in GHL workflow; verify x-wh-signature when secret is set
# Inbound webhook: GHL receives signup form data (email, name, signupType: Host|Nanny)
GHL_INBOUND_WEBHOOK_URL=

# Database (PostgreSQL — required; app uses SQL instead of Airtable)
# Create DB and run: psql "$DATABASE_URL" -f scripts/schema.sql
DATABASE_URL=postgresql://user:password@localhost:5432/nanny_wisperer

# SMTP2Go (email notifications via HTTP API)
SMTP2GO_API_KEY=
SMTP2GO_FROM_EMAIL=noreply@nannywhisperer.com
SMTP2GO_FROM_NAME=Nanny Whisperer

# Vercel Blob (profile image uploads — create store in Vercel Dashboard → Storage)
# BLOB_READ_WRITE_TOKEN=
